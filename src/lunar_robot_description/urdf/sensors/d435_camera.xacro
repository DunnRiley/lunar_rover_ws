<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  
  <!-- 
    Intel RealSense D435 - FIXED FRAME NAMES
    Ensures Gazebo publishes with correct frame IDs
  -->
  
  <xacro:macro name="realsense_d435" params="parent_link xyz rpy prefix:=camera">
    
    <!-- Rotation joint for camera -->
    <joint name="${prefix}_mount_joint" type="revolute">
      <parent link="${parent_link}"/>
      <child link="${prefix}_mount_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-3.14159" upper="3.14159" effort="10.0" velocity="1.0"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    
    <link name="${prefix}_mount_link">
      <inertial>
        <mass value="0.005"/>
        <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
      </inertial>
    </link>
    
    <!-- Camera tilted DOWN by 20 degrees (0.35 rad) to see ground -->
    <joint name="${prefix}_joint" type="fixed">
      <parent link="${prefix}_mount_link"/>
      <child link="${prefix}_link"/>
      <origin xyz="0 0 0" rpy="0 0.35 0"/>
    </joint>
    
    <!-- Main camera body -->
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.090 0.025 0.025"/>
        </geometry>
        <material name="camera_gray">
          <color rgba="0.5 0.5 0.5 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.090 0.025 0.025"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.072"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
      </inertial>
    </link>
    
    <!-- Depth frame -->
    <joint name="${prefix}_depth_joint" type="fixed">
      <parent link="${prefix}_link"/>
      <child link="${prefix}_depth_frame"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    
    <link name="${prefix}_depth_frame"/>
    
    <!-- Depth optical frame -->
    <joint name="${prefix}_depth_optical_joint" type="fixed">
      <parent link="${prefix}_depth_frame"/>
      <child link="${prefix}_depth_optical_frame"/>
      <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
    </joint>
    
    <link name="${prefix}_depth_optical_frame"/>
    
    <!-- Color frame -->
    <joint name="${prefix}_color_joint" type="fixed">
      <parent link="${prefix}_link"/>
      <child link="${prefix}_color_frame"/>
      <origin xyz="0 0.015 0" rpy="0 0 0"/>
    </joint>
    
    <link name="${prefix}_color_frame"/>
    
    <!-- Color optical frame -->
    <joint name="${prefix}_color_optical_joint" type="fixed">
      <parent link="${prefix}_color_frame"/>
      <child link="${prefix}_color_optical_frame"/>
      <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
    </joint>
    
    <link name="${prefix}_color_optical_frame"/>
    
    <!-- Gazebo sensors with FIXED frame_id -->
    <gazebo reference="${prefix}_link">
      <!-- Depth camera -->
      <sensor name="${prefix}_depth" type="depth_camera">
        <update_rate>30</update_rate>
        <topic>${prefix}/depth</topic>
        <always_on>1</always_on>
        <visualize>false</visualize>
        
        <camera>
          <horizontal_fov>1.5184</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R_FLOAT32</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>10.0</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.001</stddev>
          </noise>
        </camera>
        
        <!-- CRITICAL: Set correct frame_id -->
        <frame_id>${prefix}_depth_optical_frame</frame_id>
      </sensor>
      
      <!-- RGB camera -->
      <sensor name="${prefix}_color" type="camera">
        <update_rate>30</update_rate>
        <topic>${prefix}/color</topic>
        <always_on>1</always_on>
        <visualize>false</visualize>
        
        <camera>
          <horizontal_fov>1.211</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
        
        <!-- CRITICAL: Set correct frame_id -->
        <frame_id>${prefix}_color_optical_frame</frame_id>
      </sensor>
      
      <material>
        <ambient>0.5 0.5 0.5 1</ambient>
        <diffuse>0.5 0.5 0.5 1</diffuse>
      </material>
    </gazebo>
    
  </xacro:macro>
  
</robot>