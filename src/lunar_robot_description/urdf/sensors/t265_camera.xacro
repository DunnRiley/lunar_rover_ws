<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  
  <!-- 
    Intel RealSense T265 - FIXED FRAME NAMES
  -->
  
  <xacro:macro name="realsense_t265" params="parent_link xyz rpy prefix:=camera_rear">
    
    <!-- Rotation joint for camera -->
    <joint name="${prefix}_mount_joint" type="revolute">
      <parent link="${parent_link}"/>
      <child link="${prefix}_mount_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-3.14159" upper="3.14159" effort="10.0" velocity="1.0"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    
    <link name="${prefix}_mount_link">
      <inertial>
        <mass value="0.005"/>
        <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
      </inertial>
    </link>
    
    <!-- Camera link attached to rotating mount -->
    <joint name="${prefix}_joint" type="fixed">
      <parent link="${prefix}_mount_link"/>
      <child link="${prefix}_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    
    <!-- Main camera body -->
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.108 0.025 0.013"/>
        </geometry>
        <material name="camera_gray">
          <color rgba="0.2 0.2 0.2 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.108 0.025 0.013"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.055"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
      </inertial>
    </link>
    
    <!-- Color frame -->
    <joint name="${prefix}_color_joint" type="fixed">
      <parent link="${prefix}_link"/>
      <child link="${prefix}_color_frame"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    
    <link name="${prefix}_color_frame"/>
    
    <!-- Color optical frame -->
    <joint name="${prefix}_color_optical_joint" type="fixed">
      <parent link="${prefix}_color_frame"/>
      <child link="${prefix}_color_optical_frame"/>
      <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
    </joint>
    
    <link name="${prefix}_color_optical_frame"/>
    
    <!-- Gazebo sensor with FIXED frame_id -->
    <gazebo reference="${prefix}_link">
      <sensor name="${prefix}_color" type="camera">
        <update_rate>30</update_rate>
        <topic>${prefix}/image</topic>
        <always_on>true</always_on>
        <visualize>false</visualize>
        <enable_metrics>false</enable_metrics>
        
        <camera>
          <horizontal_fov>1.571</horizontal_fov>
          <image>
            <width>848</width>
            <height>800</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.001</stddev>
          </noise>
        </camera>
        
        <!-- CRITICAL: Set correct frame_id -->
        <frame_id>${prefix}_color_optical_frame</frame_id>
      </sensor>
      
      <material>
        <ambient>0.2 0.2 0.2 1</ambient>
        <diffuse>0.3 0.3 0.3 1</diffuse>
      </material>
    </gazebo>
    
  </xacro:macro>
  
</robot>