// ACTUATOR ENCODER READOUTS
//reads left encoder vals
void leftEncoderISR() {
  bool a = digitalRead(ActuatorEncoder1A);
  bool b = digitalRead(ActuatorEncoder1B);

  if (a == b) leftActuatorCount++;
  else        leftActuatorCount--;
}

